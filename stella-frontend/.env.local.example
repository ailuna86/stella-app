# Copy this file to .env.local and fill in real values (do not commit .env.local).

# Required in production — signs/encrypts the login session cookie so it
# can't be forged (see lib/server/session.ts). Must be at least 32
# characters, completely random. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-32+-character-string

# Email sending (Resend — https://resend.com, free tier covers a pilot easily).
# Without these, confirmation codes show on the sign-in screen instead of
# being emailed (fine for local testing, not for a real pilot).
#   1. Create a free Resend account and verify a sending domain (or use
#      their onboarding@resend.dev address for quick testing).
#   2. Create an API key in the Resend dashboard.
RESEND_API_KEY=re_...
RESEND_FROM="ST.ELLA <login@yourdomain.com>"

# Needed for the evaluation pipeline (unchanged from earlier versions).
OPENAI_API_KEY=sk-...
# Pipeline locations — required now that frontend_v8 lives outside the
# "full pipleine" folder (moved here to escape OneDrive sync corruption).
# Without these, the app falls back to assuming the pipelines are sibling
# folders of frontend_v8, which is no longer true.
STELLA_GOLD_PIPELINE_DIR=C:\dev\full pipleine
STELLA_GOLD_ENGINE_CONFIG=gold_engine_commands_full_v1_4_13.json
# LRET's canonical lexical registries (positive collocations, lexical
# registry, discourse markers, enhance thesaurus). Used to default to a
# hardcoded path baked into the orchestrator's source, which only worked on
# this one machine — now required as an env var everywhere except this
# machine's existing local setup (which still falls back to the old default
# if this is left unset). Point it at the
# final_app_registries_v3_CONSOLIDATED_CANONICAL folder.
STELLA_CANONICAL_RESOURCES_DIR=C:\dev\stella-frontend\app\resources
# Premium pipeline — only set this once full_premium_v1 has a permanent home
# (it currently only exists in a scratch folder; see the pilot testing plan).
STELLA_PIPELINE_DIR=C:\path\to\full_premium_v1
